// Copy this file to Configs/Local.xcconfig and fill in your own values.
// Local.xcconfig is gitignored — it's the place for personal config.

// Find your Team ID at https://developer.apple.com/account → Membership.
DEVELOPMENT_TEAM = ABCDE12345

// Reverse-domain prefix you control on the Apple Developer portal.
// All bundle IDs and the App Group derive from this.
BUNDLE_ID_PREFIX = com.yourname.mandroidfinder
